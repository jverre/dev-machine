{
  "compilerOptions": {
    "allowJs": false,
    "esModuleInterop": true,
    "lib": ["ES2023"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "noEmit": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "strict": true,
    "target": "ES2023",
    "types": ["@cloudflare/workers-types"]
  },
  "include": ["src/**/*.ts"]
}
