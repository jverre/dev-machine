#!/usr/bin/env bash
set -euo pipefail

command="${1:-help}"

die() {
  printf 'error: %s\n' "$*" >&2
  exit 1
}

require_doctl() {
  if ! command -v doctl >/dev/null 2>&1; then
    die "doctl is required. Install it and run: doctl auth init"
  fi
}

droplet_id() {
  if [[ -n "${DIGITALOCEAN_DROPLET_ID:-}" ]]; then
    printf '%s\n' "$DIGITALOCEAN_DROPLET_ID"
    return
  fi

  if [[ -z "${DIGITALOCEAN_DROPLET_NAME:-}" ]]; then
    die "set DIGITALOCEAN_DROPLET_ID or DIGITALOCEAN_DROPLET_NAME"
  fi

  local id
  id="$(doctl compute droplet list --format ID,Name --no-header |
    awk -v name="$DIGITALOCEAN_DROPLET_NAME" '$2 == name { print $1; exit }'
  )"

  [[ -n "$id" ]] || die "no Droplet found named ${DIGITALOCEAN_DROPLET_NAME}"
  printf '%s\n' "$id"
}

case "$command" in
  status)
    require_doctl
    doctl compute droplet list
    ;;
  power-on|up)
    require_doctl
    id="$(droplet_id)"
    doctl compute droplet-action power-on "$id" --wait
    ;;
  shutdown|down)
    require_doctl
    id="$(droplet_id)"
    doctl compute droplet-action shutdown "$id" --wait
    ;;
  power-off)
    require_doctl
    id="$(droplet_id)"
    doctl compute droplet-action power-off "$id" --wait
    ;;
  help|*)
    cat <<'EOF'
Usage:
  scripts/devbox status
  scripts/devbox up
  scripts/devbox down
  scripts/devbox power-off

Environment:
  DIGITALOCEAN_DROPLET_ID      preferred when known
  DIGITALOCEAN_DROPLET_NAME    fallback lookup by name

Note:
  This is a local convenience wrapper while the MCP server is being built.
  DigitalOcean powered-off droplets usually still reserve billable resources.
  For true cost savings, add snapshot + destroy + recreate workflow later.
EOF
    ;;
esac
