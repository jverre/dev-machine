#!/usr/bin/env bash
set -euo pipefail

command="${1:-help}"

require_doctl() {
  if ! command -v doctl >/dev/null 2>&1; then
    printf 'doctl is required. Install it and run: doctl auth init\n' >&2
    exit 1
  fi
}

droplet_id() {
  if [[ -n "${DIGITALOCEAN_DROPLET_ID:-}" ]]; then
    printf '%s\n' "$DIGITALOCEAN_DROPLET_ID"
    return
  fi

  if [[ -z "${DIGITALOCEAN_DROPLET_NAME:-}" ]]; then
    printf 'Set DIGITALOCEAN_DROPLET_ID or DIGITALOCEAN_DROPLET_NAME.\n' >&2
    exit 1
  fi

  doctl compute droplet list --format ID,Name --no-header |
    awk -v name="$DIGITALOCEAN_DROPLET_NAME" '$2 == name { print $1; exit }'
}

case "$command" in
  status)
    require_doctl
    doctl compute droplet list
    ;;
  power-on|up)
    require_doctl
    id="$(droplet_id)"
    doctl compute droplet-action power-on "$id" --wait
    ;;
  shutdown|down)
    require_doctl
    id="$(droplet_id)"
    doctl compute droplet-action shutdown "$id" --wait
    ;;
  power-off)
    require_doctl
    id="$(droplet_id)"
    doctl compute droplet-action power-off "$id" --wait
    ;;
  help|*)
    cat <<'EOF'
Usage:
  scripts/devbox status
  scripts/devbox up
  scripts/devbox down
  scripts/devbox power-off

Environment:
  DIGITALOCEAN_DROPLET_ID      preferred when known
  DIGITALOCEAN_DROPLET_NAME    fallback lookup by name

Note:
  DigitalOcean powered-off droplets usually still reserve billable resources.
  For true cost savings, add snapshot + destroy + recreate workflow later.
EOF
    ;;
esac
